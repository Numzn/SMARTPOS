{
  "name": "smart-pos-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "dev:stack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "test": "node test-connection.js",
    "test-sale": "node create-test-sale.js",
    "mock-vsdc": "node mock-vsdc-server.js",
    "check-db": "node check-database.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "setup-db": "npx prisma db push && npx prisma db seed",
    "compliance": "node docs/compliance-checker.js",
    "compliance-roadmap": "node docs/compliance-checker.js --roadmap",
    "build:init": "node -e \"require('./docs/api-reference-manager').createReferenceIndex()\"",
    "build:validate": "node docs/build-validator.js",
    "build:progress": "node -e \"require('./docs/api-reference-manager').showProgress()\"",
    "build:tasks": "node -e \"require('./docs/api-reference-manager').getNextTasks()\"",
    "build:history": "node -e \"require('./docs/api-reference-manager').showBuildHistory()\"",
    "status": "npm run build:progress",
    "validate": "npm run build:validate",
    "tasks": "npm run build:tasks",
    "vsdc:update": "node -e \"const args=process.argv.slice(2); require('./docs/api-reference-manager').updateImplementationStatus(args[0], args[1])\"",
    "check": "npm run validate && npm run status && npm run tasks",
    "validate:system": "node scripts/validate-system.js",
    "validate:frontend": "node scripts/validate-frontend-backend.js",
    "validate:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-and-validate.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.1.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "prisma": "^6.11.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
