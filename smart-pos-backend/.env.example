# Server
PORT=4000
JWT_SECRET=change-me-in-production

# Self-hosted PostgreSQL (see docker-compose.yml or your own Postgres server)
DATABASE_URL="postgresql://smartpos:smartpos_dev_change_me@localhost:5432/smartpos"

# --- VSDC mode: mock (local dev) | sandbox | production ---
# Mock server for development: npm run mock-vsdc
VSDC_URL=http://localhost:8090
VSDC_USERNAME=dev-user
VSDC_PASSWORD=dev-password

# Real ZRA VSDC sandbox / production (replace mock URL and credentials when certifying)
# VSDC_URL=https://sandbox-vsdc.zra.org.zm
# VSDC_USERNAME=your-zra-issued-username
# VSDC_PASSWORD=your-zra-issued-password
# DVC_SRL_NO=your-registered-device-serial-from-zra

# Business identity (required for init + invoices)
BUSINESS_TPIN=1000000000
BRANCH_ID=000

# Product registration: when true (default), product create/update fails if VSDC item save fails
ZRA_REGISTRATION_STRICT=true
