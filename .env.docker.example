# Smart POS docker-compose overrides.
# Copy to `.env` next to docker-compose.yml to customise the stack.

# Postgres
POSTGRES_USER=smartpos
POSTGRES_PASSWORD=smartpos_dev_change_me
POSTGRES_DB=smartpos
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
JWT_SECRET=change-me-in-production
SEED_ON_BOOT=true

# ZRA / VSDC (defaults wire to the mock-vsdc service)
VSDC_URL=http://mock-vsdc:8090
VSDC_USERNAME=dev-user
VSDC_PASSWORD=dev-password
BUSINESS_TPIN=1000000000
BRANCH_ID=000

# Mock VSDC
MOCK_VSDC_PORT=8090

# Frontend (nginx)
FRONTEND_PORT=8080
