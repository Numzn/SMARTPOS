{
  "name": "smart-pos-workspace",
  "version": "1.0.0",
  "description": "Smart POS System - Full Stack Development Workspace",
  "main": "dev-helper.js",
  "scripts": {
    "status": "node dev-helper.js status",
    "frontend": "node dev-helper.js frontend run dev",
    "backend": "node dev-helper.js backend run dev",
    "start": "node dev-helper.js start",
    "install-all": "node dev-helper.js install",
    "migrate": "node dev-helper.js migrate",
    "test": "node dev-helper.js test",
    "build": "node dev-helper.js frontend run build",
    "frontend:build": "node dev-helper.js frontend run build",
    "frontend:install": "cd smart-pos-frontend && npm install",
    "backend:install": "cd smart-pos-backend && npm install",
    "backend:generate": "cd smart-pos-backend && npx prisma generate",
    "backend:reset": "cd smart-pos-backend && npx prisma migrate reset",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:rebuild": "docker compose build --no-cache && docker compose up -d",
    "docker:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/docker-smoke.ps1",
    "docker:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/status.ps1",
    "deploy:numzlab": "bash scripts/deploy-numzlab.sh",
    "deploy:numzlab:update": "bash scripts/deploy-numzlab.sh --pull --no-seed",
    "help": "node dev-helper.js"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "react",
    "node",
    "express",
    "prisma",
    "postgresql",
    "zra-compliance"
  ],
  "author": "Smart POS Development Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "workspaces": [
    "smart-pos-frontend",
    "smart-pos-backend"
  ],
  "dependencies": {
    "framer-motion": "^12.23.6",
    "lucide-react": "^0.525.0"
  }
}
